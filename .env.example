APP_ENV=prod
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

RABBITMQ_URL=amqp://user:password@rabbitmq-host:5672/

AWS_REGION=ap-northeast-2
S3_DATASET_BUCKET=your-dataset-bucket
S3_DATASET_PREFIX=datasets
S3_MODEL_BUCKET=capstone-gachon
S3_MODEL_PREFIX=models

MODEL_SOURCE=s3
ACTIVE_MODEL_VERSION=2026-04-14-001
MODEL_LOCAL_CACHE_DIR=/app/.cache/model-cache

LLM_PROVIDER=school
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_OUTPUT_TOKENS=800

SCHOOL_LLM_BASE_URL=http://cellm.gachon.ac.kr:8000/v1
SCHOOL_LLM_API_KEY=replace-with-school-llm-api-key
SCHOOL_LLM_MODEL=replace-with-school-llm-model

OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

TRAINING_SAFE_MODE=true
